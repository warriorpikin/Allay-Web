  "semantic": {
    "color": {
      "background": "{primitive.color.ivory}",
      "surface": "{primitive.color.cream}",
      "surface-alt": "{primitive.color.stone}",
      "primary": "{primitive.color.espresso}",
      "primary-hover": "{primitive.color.brown}",
      "secondary": "{primitive.color.beige}",
      "text": "{primitive.color.espresso}",
      "text-soft": "{primitive.color.muted-brown}",
      "success": "{primitive.color.olive}",
      "error": "#8A4B3B"
    }
  },
  "component": {
    "button-primary": { "background": "{semantic.color.primary}", "foreground": "{primitive.color.cream}", "radius": "{primitive.radius.pill}" },
    "card": { "background": "{semantic.color.surface}", "radius": "{primitive.radius.lg}" },
    "input": { "background": "{semantic.color.surface}", "border": "rgba(55, 36, 24, 0.14)", "radius": "{primitive.radius.sm}" }
  }
}
