VITE_API_URL=http://localhost:5000/api
# Set to the real production domain in production (e.g. https://www.allayhouse.com) —
# used for canonical URLs, Open Graph/Twitter image URLs, and structured data.
VITE_SITE_URL=http://localhost:5173
VITE_PAYSTACK_PUBLIC_KEY=
VITE_GA4_MEASUREMENT_ID=G-7DZHH9ENGG
VITE_GA4_ENABLED=true
VITE_GA4_DEBUG=false

# Optional: Google Search Console HTML-tag verification code (the "content"
# value only, not the full <meta> tag). Leave blank to omit the tag entirely.
VITE_GOOGLE_SITE_VERIFICATION=

# Recipient for the contact page's mailto: inquiry form. Falls back to
# help@allayhouse.con (exact spelling, not a typo to "fix") in code if unset —
# change this value here rather than editing Contact.jsx when the real
# address is confirmed.
VITE_CONTACT_EMAIL=help@allayhouse.con


