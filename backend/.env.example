NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# PostgreSQL / Neon. Add ?sslmode=require for hosted Neon databases.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/allay_house
DATABASE_SSL=false

# Generate a long random value before running outside local development.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h

# Used once by: npm run admin:create -w backend
INITIAL_ADMIN_NAME=Allay House Admin
INITIAL_ADMIN_EMAIL=admin@allayhouse.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

# Phase 2+
RESEND_API_KEY=
RESEND_FROM_EMAIL=Allay House <hello@allayhouse.com>
EMAIL_FROM=Allay House <hello@allayhouse.com>
ADMIN_EMAIL=
ADMIN_NOTIFICATION_EMAIL=

# Backend-only Cloudinary credentials for admin service/testimonial image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Backend-only GA4 reporting credentials. Do not expose service-account values to Vite.
GA4_PROPERTY_ID=545261405
GA4_CLIENT_EMAIL= allay-service@allayhouse.iam.gserviceaccount.com
GA4_PRIVATE_KEY=5193830a87d207c0fd021036f4bc2dd427dc934c
GA4_ANALYTICS_ENABLED=true
GA4_CACHE_TTL_SECONDS=600
GA4_REALTIME_CACHE_TTL_SECONDS=60

# Admin uploads use Cloudinary. Do not expose these values through frontend/Vite env.
UPLOAD_STORAGE_DRIVER=cloudinary

# Launch coupon for waitlist members. Used by the (manually triggered) launch email template.
WAITLIST_LAUNCH_COUPON_CODE=ALLAYEARLY
WAITLIST_LAUNCH_DISCOUNT_TYPE=percent
WAITLIST_LAUNCH_DISCOUNT_VALUE=15

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
