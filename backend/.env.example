NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# PostgreSQL / Neon. Add ?sslmode=require for hosted Neon databases.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/allay_house
DATABASE_SSL=false

# Generate a long random value before running outside local development.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h

# Used once by: npm run admin:create -w backend
INITIAL_ADMIN_NAME=Allay House Admin
INITIAL_ADMIN_EMAIL=admin@allayhouse.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

# Phase 2+
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@allayhouse.com
RESEND_FROM_NAME=Allay House
RESEND_REPLY_TO=hello@allayhouse.com
EMAIL_FROM=Allay House <hello@allayhouse.com>
ADMIN_EMAIL=
ADMIN_NOTIFICATION_EMAIL=

# Backend-only Cloudinary credentials for admin service/testimonial image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Backend-only GA4 reporting credentials. Do not expose service-account values to Vite.
GA4_PROPERTY_ID=545261405
GA4_CLIENT_EMAIL= allay-service@allayhouse.iam.gserviceaccount.com
GA4_PRIVATE_KEY=5193830a87d207c0fd021036f4bc2dd427dc934c
GA4_ANALYTICS_ENABLED=true
GA4_CACHE_TTL_SECONDS=600
GA4_REALTIME_CACHE_TTL_SECONDS=60

# Admin uploads use Cloudinary. Do not expose these values through frontend/Vite env.
UPLOAD_STORAGE_DRIVER=cloudinary

# Launch coupon for waitlist members. Used by the (manually triggered) launch email template.
# WAITLIST_LAUNCH_DISCOUNT_VALUE/TYPE is also the single source of truth for the
# discount shown in the waitlist coupon email — there is no separate "percent" setting.
WAITLIST_LAUNCH_COUPON_CODE=ALLAYEARLY
WAITLIST_LAUNCH_DISCOUNT_TYPE=percent
WAITLIST_LAUNCH_DISCOUNT_VALUE=15

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Outgoing-email reply/support configuration. EMAIL_DEFAULT_REPLY_TO falls back to
# RESEND_REPLY_TO above when unset, so it usually does not need to be set separately.
EMAIL_DEFAULT_REPLY_TO=
EMAIL_SUPPORT_ADDRESS=
# Required only to enable the admin composer's "No replies" option.
EMAIL_NO_REPLY_ADDRESS=

# Public website links used in emails. Both fall back to FRONTEND_URL above when unset.
ALLAY_SERVICES_URL=
# Email background/logo. Fall back to the existing public hero image and brown
# logo already served by the frontend (FRONTEND_URL + /images/...) when unset.
ALLAY_EMAIL_BACKGROUND_URL=
ALLAY_EMAIL_LOGO_URL=

# Comma-separated allow-list for waitlist coupon *test* sends only (admin "Send test"
# action). Real waitlist coupon sends never use this list.
WAITLIST_COUPON_TEST_RECIPIENTS=

# Admin campaign bulk-send controls. Safe defaults apply if left blank.
EMAIL_BATCH_SIZE=25
EMAIL_BATCH_DELAY_MS=1000
EMAIL_MAX_RECIPIENTS_PER_CAMPAIGN=1000
